{
  "name": "fixmylife-ai",
  "version": "1.0.0",
  "description": "An AI-powered everyday problem-solving app",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd frontend && npm start\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm start",
    "test": "cd backend && npm test"
  },
  "keywords": [
    "AI",
    "problem-solving",
    "assistant",
    "government",
    "jobs",
    "finance"
  ],
  "author": "FixMyLife Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^7.6.0"
  }
}
